# ============================================================
#  SERVER ENVIRONMENT CONFIG
#  LOCAL ke liye yeh values use hongi
#  Production pe ye file change karo ya environment variables set karo
# ============================================================

# ------- LOCAL MySQL (apna local MySQL ka password yahan dalo) -------
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=Ipo@1234
MYSQL_DATABASE=newipo_db
MYSQL_PORT=3306

# ------- PRODUCTION MySQL (uncomment karo production pe) -------
# MYSQL_HOST=127.0.0.1
# MYSQL_USER=u521845907_newipo_user
# MYSQL_PASSWORD=NewIpo@1234
# MYSQL_DATABASE=u521845907_newipo_db
# MYSQL_PORT=3306

# ------- Server Port -------
PORT=5000

# ------- Environment -------
NODE_ENV=development

# ------- Uploads path -------
# LOCAL: yahan local folder path dalo (folder exist karna chahiye)
UPLOADS_PATH=./uploads

# PRODUCTION: uncomment karo production pe
# UPLOADS_PATH=/home/u521845907/domains/padmanutri.com/public_html/ipo/uploads
